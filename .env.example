# Database (Railway injeta automaticamente via ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT
JWT_SECRET=your-super-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Redis (Railway injeta automaticamente via ${{Redis.REDIS_URL}})
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
